# AgentGuard configuration example.
# Copy to .env and adjust values for your deployment.

# Gateway listener
AGENTGUARD_HOST=0.0.0.0
AGENTGUARD_PORT=8080

# Upstream backend that the gateway forwards sanitized traffic to.
AGENTGUARD_UPSTREAM_URL=http://mock-backend:9000

# Redis used by the idempotency middleware.
AGENTGUARD_REDIS_URL=redis://redis:6379/0

# PostgreSQL used by the HITL request registry.
AGENTGUARD_POSTGRES_DSN=postgresql+asyncpg://agentguard:agentguard@postgres:5432/agentguard

# Shared HMAC secret used to verify asynchronous approval callbacks
# (simulates an OAuth 2.0 CIBA-signed approval token).
AGENTGUARD_HITL_HMAC_SECRET=change-me-hitl-shared-secret

# Optional webhook pushed when a HITL ticket is created.
AGENTGUARD_HITL_WEBHOOK_URL=http://approval-console:9001/inbox

# Policy / DLP configuration files.
AGENTGUARD_POLICIES_PATH=/app/configs/policies.yaml
AGENTGUARD_DLP_RULES_PATH=/app/configs/dlp_rules.yaml

# Idempotency TTL in seconds (default: 1 hour).
AGENTGUARD_IDEMPOTENCY_TTL=3600
